# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# large media — story video is derived/backed up elsewhere, not tracked in git
# (GitHub rejects files >100MB; keep history clean and rely on a hosted video provider)
stories/**/*.mp4
stories/**/*.mov
stories/**/*.webm
*.mp4
*.mov
*.webm

# photogrammetry room scans — large binaries, delivered/hosted out of band
# (see docs/world/SCAN_CAPTURE.md)
public/scans/**
*.glb
*.gltf
*.ply
*.splat
*.ksplat

# 360° panorama room environments (see docs/world/PANORAMA_ENVIRONMENTS.md)
public/panos/**

# Gaussian splat room captures (see docs/world/SPLAT_CAPTURE.md)
public/splats/**

# typescript
*.tsbuildinfo
next-env.d.ts
